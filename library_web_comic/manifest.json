{
  "manifest_version": 3,
  "name": "Web漫画 管理",
  "description": "ページ情報を取得して本棚・お気に入りを管理する拡張（タグ・同期・バックアップ対応）",
  "version": "1.0.0",
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "permissions": [
  "storage",
  "activeTab",
  "scripting",
  "clipboardWrite",
  "alarms"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "host_permissions": [],
  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'self'"
  }
}